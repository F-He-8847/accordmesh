root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

[*.{ts,tsx,js,mjs,css,md}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
